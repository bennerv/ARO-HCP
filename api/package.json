{
  "dependencies": {
    "@azure-tools/typespec-autorest": "^0.65.0",
    "@azure-tools/typespec-azure-core": "^0.65.0",
    "@azure-tools/typespec-azure-resource-manager": "^0.65.0",
    "@azure-tools/typespec-azure-rulesets": "0.65.0",
    "@azure-tools/typespec-client-generator-core": "^0.65.0",
    "@azure-tools/typespec-go": "^0.10.0",
    "@typespec/http": "~1.9.0",
    "@typespec/openapi": "~1.9.0",
    "@typespec/openapi3": "~1.9.0",
    "@typespec/rest": "~0.79.0",
    "@typespec/versioning": "~0.79.0",
    "oav": "^4.0.2"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "format": "tsp format \"**/*.tsp\"",
    "format-check": "tsp format --check \"**/*.tsp\"",
    "compile": "tsp compile redhatopenshift/HcpCluster.Management --warn-as-error",
    "models": "tsp compile redhatopenshift/HcpCluster.Management --emit @azure-tools/typespec-go --option @azure-tools/typespec-go.emitter-output-dir={project-root}/../../../internal/api/${VERSION}/generated --option @azure-tools/typespec-go.module=github.com/Azure/ARO-HCP/internal/api/${VERSION}/generated --option @azure-tools/typespec-go.generate-fakes=false --option @azure-tools/typespec-go.generate-samples=false --option @azure-tools/typespec-go.inject-spans=false --option @azure-tools/typespec-go.remove-unreferenced-types=true --option @azure-tools/typespec-go.fix-const-stuttering=true --option @azure-tools/typespec-go.head-as-boolean=true --option @azure-tools/typespec-go.flavor=azure --option @azure-tools/typespec-go.azure-arm=true --option @azure-tools/typespec-go.disallow-unknown-fields=true --option @azure-tools/typespec-go.api-version=$(echo ${VERSION} | sed 's/^v//' | sed 's/\\([0-9]\\{4\\}\\)\\([0-9]\\{2\\}\\)\\([0-9]\\{2\\}\\)/\\1-\\2-\\3-/')",
    "testsdk": "tsp compile redhatopenshift/HcpCluster.Management --emit @azure-tools/typespec-go --option @azure-tools/typespec-go.emitter-output-dir={project-root}/../../../test/sdk/resourcemanager/redhatopenshifthcp/armredhatopenshifthcp --option @azure-tools/typespec-go.module=github.com/Azure/ARO-HCP/test/sdk/resourcemanager/redhatopenshifthcp/armredhatopenshifthcp --option @azure-tools/typespec-go.generate-fakes=true --option @azure-tools/typespec-go.generate-samples=false --option @azure-tools/typespec-go.inject-spans=true --option @azure-tools/typespec-go.fix-const-stuttering=true --option @azure-tools/typespec-go.head-as-boolean=true --option @azure-tools/typespec-go.flavor=azure --option @azure-tools/typespec-go.azure-arm=true --option @azure-tools/typespec-go.api-version=$(echo ${VERSION} | sed 's/^v//' | sed 's/\\([0-9]\\{4\\}\\)\\([0-9]\\{2\\}\\)\\([0-9]\\{2\\}\\)/\\1-\\2-\\3-/')"
  },
  "devDependencies": {
    "@typespec/compiler": "~1.9.0",
    "@microsoft.azure/openapi-validator": "2.2.4",
    "@microsoft.azure/openapi-validator-rulesets": "2.2.1"
  }
}
